{
  "name": "ldr-ui-tests",
  "version": "1.0.0",
  "description": "UI tests for Local Deep Research using Puppeteer",
  "scripts": {
    "test": "node run_all_tests.js",
    "test:auth": "node test_auth_flow.js",
    "test:pages": "node test_pages_browser.js",
    "test:settings": "node test_settings_page.js",
    "test:navigation": "node test_full_navigation.js",
    "test:navigation:search": "node test_full_navigation.js --search",
    "test:workflow": "node test_complete_workflow.js",
    "test:workflow:headless": "node test_complete_workflow.js --headless",
    "test:simple": "node test_simple_auth.js",
    "test:research": "node test_research_submit.js",
    "test:research:api": "node test_research_api.js",
    "test:research:diagnosis": "node test_research_diagnosis.js",
    "test:research:simple": "node test_research_simple.js",
    "test:research:verify": "node test_research_verify.js",
    "test:research:fixed": "node test_research_fixed_model.js",
    "test:research:working": "node test_research_working_config.js",
    "test:models": "node check_available_models.js",
    "test:mobile": "node mobile/test_mobile_navigation_ci.js",
    "test:mobile:visual": "HEADLESS=false node mobile/test_mobile_navigation_ci.js",
    "test:mobile:json": "OUTPUT_FORMAT=json node mobile/test_mobile_navigation_ci.js",
    "test:mobile:junit": "OUTPUT_FORMAT=junit node mobile/test_mobile_navigation_ci.js",
    "test:mobile:screenshots": "node mobile/test_mobile_nav_all_pages.js",
    "test:mobile:comprehensive": "node mobile/test_mobile_ui_comprehensive.js",
    "test:mobile:research": "node mobile/test_research_page_mobile.js",
    "test:mobile:research:visual": "HEADLESS=false node mobile/test_research_page_mobile.js",
    "test:mobile:layout": "node mobile/test_layout_bugs_ci.js",
    "install-browsers": "npx puppeteer browsers install chrome"
  },
  "dependencies": {
    "puppeteer": "^25.1.0"
  },
  "overrides": {
    "yauzl": "^3.2.1"
  },
  "main": "auth_helper.js",
  "directories": {
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
